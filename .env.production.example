# Production environment template for the single-Droplet deployment.
#
# Copy this file to .env.production and fill in the blank values:
#     cp .env.production.example .env.production
#
# WARNINGS
#   - NEVER commit .env.production. Only this .example template is tracked.
#   - NEVER put provider keys in NEXT_PUBLIC_ variables. Nothing here is exposed
#     to the browser; the frontend reads OPS_API_URL only in server code.
#   - Generate each encryption key INDEPENDENTLY with a cryptographically secure
#     generator (see DEPLOY_DIGITALOCEAN.md). Do not reuse one key for both.
#   - Retain the SAME SECRET_VAULT_KEY (and LANGGRAPH_AES_KEY) across every
#     redeployment. If the vault key changes, previously stored secrets and
#     checkpoints become permanently unreadable.

# ── Reverse proxy / TLS ───────────────────────────────────────────────────────
# Public hostname whose DNS A record points at the Droplet. Caddy issues HTTPS
# for this name automatically. For an IP-only development fallback use ":80"
# (plain HTTP, no certificate) — see deploy/Caddyfile.
DOMAIN=your-domain.example
# Optional: email used only for certificate expiry notices.
ACME_EMAIL=
# Basic Auth protects every public route except /healthz. Generate a Caddy
# bcrypt hash with: caddy hash-password
OPS_BASIC_AUTH_USER=ops-admin
OPS_BASIC_AUTH_HASH=replace-with-caddy-bcrypt-hash

# ── Frontend (server-only) ────────────────────────────────────────────────────
# Internal address of the API on the private Docker network. Read only by
# Next.js server code. Do not point this at a public URL.
OPS_API_URL=http://api:8000
# Shared internal API token. This is passed only to the API and web containers;
# it must never be exposed as NEXT_PUBLIC_*.
OPS_INTERNAL_API_TOKEN=replace-with-random-internal-token
# Server-only demo banner toggle.
OPS_DEMO_MODE=false

# ── API: cross-origin + docs ──────────────────────────────────────────────────
# Browser origin(s) allowed to call the API directly. In this topology the
# browser talks to Next.js, not the API, so this should just match your site.
OPS_CORS_ORIGINS=https://your-domain.example
# Keep API docs disabled in production.
OPS_ENABLE_API_DOCS=false

# ── API: persistent database paths (under the /data volume) ───────────────────
OPS_DB_PATH=/data/ops.db
CHECKPOINT_DB_PATH=/data/checkpoints.db
SECRET_VAULT_DB_PATH=/data/secret_vault.db
PROVIDER_EFFECTS_DB_PATH=/data/provider_effects.db

# ── Encryption keys (generate independently; keep stable across redeploys) ────
LANGGRAPH_AES_KEY=
SECRET_VAULT_KEY=

# ── Provider credentials (leave blank until you deploy with live providers) ───
PERPLEXITY_API_KEY=
GOOGLE_GENAI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=ops-assignment-user
COMPOSIO_GMAIL_CONNECTED_ACCOUNT_ID=
BROWSER_USE_API_KEY=

# ── Outreach / live-action safety (keep disabled by default) ──────────────────
# Optional vault reference that redirects vendor outreach to a controlled inbox.
OUTREACH_RECIPIENT_OVERRIDE=
# Live Gmail sending stays OFF unless explicitly authorized.
ALLOW_LIVE_VENDOR_EMAIL=false
# Browser Use stays fail-closed unless the production environment opts in. The
# reviewed app policy remains Pipedrive/Twenty only.
ALLOW_LIVE_BROWSER=false
# Local credential submission stays disabled in production.
ALLOW_LOCAL_CREDENTIAL_SUBMISSION=false
# Live provider tests stay OFF in production.
RUN_LIVE_TESTS=0
