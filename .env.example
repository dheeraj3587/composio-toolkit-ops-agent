PERPLEXITY_API_KEY=
GOOGLE_GENAI_API_KEY=
COMPOSIO_API_KEY=
BROWSER_USE_API_KEY=
LANGGRAPH_AES_KEY=
LANGGRAPH_STRICT_MSGPACK=true
SECRET_VAULT_KEY=
OPS_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
OPS_API_URL=http://127.0.0.1:8000
OPS_INTERNAL_API_TOKEN=dev-internal-token-change-me
# Local development only. Keep disabled in shared or production environments.
OPS_ENABLE_API_DOCS=true
RUN_LIVE_TESTS=0
ALLOW_LIVE_BROWSER=false
COMPOSIO_USER_ID=ops-assignment-user
COMPOSIO_GMAIL_CONNECTED_ACCOUNT_ID=
COMPANY_LEGAL_NAME=
COMPANY_WEBSITE=
COMPANY_WORK_EMAIL_REF=
COMPANY_USE_CASE=
COMPANY_EXPECTED_VOLUME=
OAUTH_CALLBACK_URLS=
OUTREACH_RECIPIENT_OVERRIDE=
ALLOW_LIVE_VENDOR_EMAIL=false
ALLOW_LOCAL_CREDENTIAL_SUBMISSION=false
MAX_OUTREACH_ROUNDS=5
MAX_UNCLEAR_RETRIES=1
MAX_BROWSER_ATTEMPTS=2
MAX_HITL_COUNT=3
OPS_DB_PATH=./private/ops.db
CHECKPOINT_DB_PATH=./private/checkpoints.db
SECRET_VAULT_DB_PATH=./private/secret_vault.db
PROVIDER_EFFECTS_DB_PATH=./private/provider_effects.db
