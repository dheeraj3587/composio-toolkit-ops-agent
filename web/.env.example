# Server-only backend origin. It is read only by Next.js server code.
# Never add a NEXT_PUBLIC_ alias: browser bundles do not need the API origin.
OPS_API_URL=http://127.0.0.1:8000

# Server-only demo banner toggle. Read only by the Next.js server layout and
# passed to client components as a plain boolean prop. Never add a NEXT_PUBLIC_
# alias: the raw flag must not be inlined into browser bundles.
OPS_DEMO_MODE=false
